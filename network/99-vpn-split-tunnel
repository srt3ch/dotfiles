#!/bin/bash

IFACE="$1"
EVENT="$2"
GATEWAY_CACHE="/run/vpn-split-tunnel-gw"

case "$EVENT" in
    up)
        # Only cache gateway for physical interfaces — virtual/tunnel interfaces
        # (pvpnksintrf0, proton0, etc.) lack a /sys/class/net/$IFACE/device entry
        if [[ -e "/sys/class/net/$IFACE/device" ]]; then
            GW=$(ip route show dev "$IFACE" | awk '/^default/ {print $3; exit}')
            if [[ -n "$GW" ]]; then
                echo "$GW $IFACE" > "$GATEWAY_CACHE"
                logger -t "vpn-split-tunnel" "Saved gateway: $GW dev $IFACE"
            fi
        fi
        # ProtonVPN uses WireGuard (proton0) — doesn't fire vpn-up
        if [[ "$IFACE" == "proton0" ]]; then
            /usr/local/bin/vpn-split-tunnel
            systemctl start vpn-split-tunnel-refresh.timer
        fi
        ;;
    down)
        if [[ "$IFACE" == "proton0" ]]; then
            systemctl stop vpn-split-tunnel-refresh.timer 2>/dev/null || true
            logger -t "vpn-split-tunnel" "VPN down — bypass routes cleared"
        fi
        ;;
    vpn-up)
        /usr/local/bin/vpn-split-tunnel
        systemctl start vpn-split-tunnel-refresh.timer
        ;;
    vpn-down)
        systemctl stop vpn-split-tunnel-refresh.timer 2>/dev/null || true
        logger -t "vpn-split-tunnel" "VPN down — bypass routes cleared"
        ;;
esac
