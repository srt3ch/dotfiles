#!/bin/bash
set -euo pipefail

DOMAINS_FILE="/etc/vpn-exclude-domains"
GATEWAY_CACHE="/run/vpn-split-tunnel-gw"
LOG_TAG="vpn-split-tunnel"

if [[ ! -f "$GATEWAY_CACHE" ]]; then
    logger -t "$LOG_TAG" "Gateway cache not found — physical interface may not be up yet"
    exit 1
fi

read -r PHYS_GW PHYS_IF < "$GATEWAY_CACHE"

if [[ -z "$PHYS_GW" || -z "$PHYS_IF" ]]; then
    logger -t "$LOG_TAG" "Invalid gateway cache contents"
    exit 1
fi

while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# || -z "${line// }" ]] && continue

    domain="${line// /}"

    for target in "$domain" "www.$domain"; do
        [[ "$target" == "www.www."* ]] && continue

        mapfile -t ips < <(dig +short +time=3 +tries=2 "$target" A 2>/dev/null \
            | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$')

        for ip in "${ips[@]:-}"; do
            [[ -z "$ip" ]] && continue
            ip route replace "$ip/32" via "$PHYS_GW" dev "$PHYS_IF" 2>/dev/null \
                && logger -t "$LOG_TAG" "Bypass: $ip ($target) via $PHYS_GW dev $PHYS_IF" \
                || logger -t "$LOG_TAG" "Failed to add bypass route for $ip ($target)"
        done
    done
done < "$DOMAINS_FILE"
